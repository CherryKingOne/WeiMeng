# App
APP_ENV=development
APP_NAME=WeiMeng
SECRET_KEY=super-secret-key-change-it
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=False

# Database
# Source mode defaults (if PostgreSQL runs in Docker on host port 5400)
POSTGRESQL_HOST=127.0.0.1
POSTGRESQL_PORT=5400
POSTGRESQL_USER=weimeng
POSTGRESQL_PASSWORD=weimeng
POSTGRESQL_DB=weimeng

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6300
REDIS_DB=0
REDIS_PASSWORD=weimeng

# MinIO
MINIO_ENDPOINT=127.0.0.1:5726
MINIO_ACCESS_KEY=weimengminio
MINIO_SECRET_KEY=weimengminio
MINIO_BUCKET_NAME=scripts
MINIO_SECURE=False

# Script Chunking
SCRIPTS_CHUNK_SIZE=1200
SCRIPTS_CHUNK_OVERLAP=200

# Script Upload Validation (per-file text length limit, not chunking)
SCRIPTS_UPLOAD_MAX_TEXT_LENGTH=10000



# Elasticsearch
ELASTICSEARCH_URL=http://127.0.0.1:7260/
ELASTICSEARCH_SCRIPT_CHUNK_INDEX=script_chunks

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
SMTP_USE_TLS=True
SMTP_FROM_NAME=WeiMeng
