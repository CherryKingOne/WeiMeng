# ==============================================
# WeiMeng System Environment Variables
# ==============================================

# ----------------------------------------------
# Docker Image Configuration
# ----------------------------------------------
API_IMAGE=vmengs/weimeng-api:0.0.1
WEB_IMAGE=vmengs/weimeng-web:0.0.1
POSTGRES_IMAGE=vmengs/postgres:latest
REDIS_IMAGE=vmengs/redis:latest
RUSTFS_IMAGE=vmengs/rustfs:latest
ELASTICSEARCH_IMAGE=vmengs/elasticsearch:latest

# ----------------------------------------------
# Backend Configuration
# ----------------------------------------------

# App Settings
APP_ENV=production
SECRET_KEY=super-secret-key-change-it
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Connection
# Internal Docker network address for API service
POSTGRESQL_HOST=postgres
POSTGRESQL_PORT=5432
POSTGRESQL_USER=weimeng
POSTGRESQL_PASSWORD=weimeng
POSTGRESQL_DB=weimeng

# Redis Connection
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=weimeng

# RustFS (S3 Compatible)
MINIO_ENDPOINT=rustfs:9000
MINIO_ACCESS_KEY=weimengrustfs
MINIO_SECRET_KEY=weimengrustfs
MINIO_BUCKET_NAME=scripts
MINIO_SECURE=False
RUSTFS_ACCESS_KEY=weimengrustfs
RUSTFS_SECRET_KEY=weimengrustfs
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_SERVER_DOMAINS=0.0.0.0

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200/
ELASTICSEARCH_SCRIPT_CHUNK_INDEX=script_chunks

# SMTP Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
SMTP_USE_TLS=True

# AI Services Configuration
# Compatible with OpenAI, DeepSeek, Moonshot, etc.
OPENAI_API_KEY=sk-placeholder
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o
OPENAI_CONTEXT_WINDOW=128000
OPENAI_STREAMING=True
OPENAI_ENABLE_REASONING=False
OPENAI_TEMPERATURE=0.7

# Langfuse Monitoring
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ----------------------------------------------
# Frontend Configuration
# ----------------------------------------------
# Public exposed ports
FRONTEND_PORT=5678
API_PORT=5607
POSTGRES_EXPOSE_PORT=5400
REDIS_EXPOSE_PORT=6300
MINIO_EXPOSE_PORT=5726
MINIO_CONSOLE_EXPOSE_PORT=7056
ELASTICSEARCH_EXPOSE_PORT=7260

# Browser-side API URL.
# Keep /api/v1 to use frontend same-origin proxy (recommended for public deployment).
NEXT_PUBLIC_API_URL=/api/v1

# Server-side SSR API URL (inside Docker network)
SERVER_API_URL=http://api:5607/api/v1
